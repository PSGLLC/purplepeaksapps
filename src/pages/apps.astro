---
import BaseLayout from '../layouts/BaseLayout.astro';

const apps = [
  {
    name: 'ProShot AI',
    badge: 'AI-Powered',
    desc: 'Sharpen, retouch, and upgrade headshots and product photos in seconds — no editing skills or software required.',
    href: 'https://proshot-ai.higgsfield.app/',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Apps | Purple Peaks Apps',
  url: 'https://purplepeaksapps.com/apps',
  description:
    'Simple, focused apps built by Purple Peaks Apps that you can use right now — no setup, no subscription required.',
};
---
<BaseLayout
  title="Apps — Simple Tools You Can Use Right Now | Purple Peaks Apps"
  description="Browse the apps built by Purple Peaks Apps, including ProShot AI, an AI-powered photo enhancement tool. No setup, no subscription required."
  path="/apps"
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Purple Peaks Apps</p>
      <h1>Apps built for the way people actually work.</h1>
      <p class="subhead">
        Simple, focused tools you can use right now — no setup, no subscription required.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <h2 class="visually-hidden">Available apps</h2>
      <div class="grid grid-3">
        {apps.map((a) => (
          <div class="card product-card">
            <span class="app-badge">{a.badge}</span>
            <h3>{a.name}</h3>
            <p>{a.desc}</p>
            <a href={a.href} target="_blank" rel="noopener noreferrer" class="btn btn-primary">Try it &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Have an idea for an app?</h2>
      <p>We'd like to hear from you.</p>
      <a href="/contact" class="btn btn-teal">Get in Touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-dark) 0%, #2b1147 100%);
    color: #fff;
    padding: 5.5rem 0;
  }
  .hero-inner { max-width: 720px; }
  .hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3.2rem); }
  .hero .eyebrow { color: var(--color-teal); }
  .subhead { font-size: 1.1rem; color: #e2d4f0; margin-bottom: 0; }

  .product-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .product-card h3 { margin-bottom: 0.2rem; }
  .product-card p { color: var(--color-text-muted); font-size: 0.95rem; flex-grow: 1; }
  .product-card .btn { align-self: flex-start; margin-top: 0.5rem; }

  .app-badge {
    display: inline-block;
    align-self: flex-start;
    background: rgba(81, 222, 204, 0.15);
    color: var(--color-purple);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    margin-bottom: 0.3rem;
  }
  :root[data-theme="dark"] .app-badge { color: var(--color-teal); }

  .cta-section {
    background: var(--color-purple);
    color: #fff;
    text-align: center;
  }
  .cta-inner h2 { color: #fff; }
  .cta-inner p { color: #f0e6f8; margin-bottom: 1.5rem; }
</style>
