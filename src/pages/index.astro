---
import BaseLayout from '../layouts/BaseLayout.astro';

const products = [
  {
    name: 'PSG Partner Portal',
    desc: 'A back-office CRM built for independent insurance agents — bringing lead management, e-signature workflows, and quoting tools into one place so agents can spend less time on admin and more time with clients.',
    href: '/portal',
    cta: 'Learn more',
  },
  {
    name: 'LearnMedicare.org',
    desc: 'Free Medicare education platform with 6-lesson video course, interactive calculators, and T65 guide lead capture.',
    href: 'https://learnmedicare.org',
    cta: 'Visit site',
    external: true,
  },
  {
    name: 'Jitsi Video Rooms',
    desc: 'Secure, self-hosted video meeting rooms for client consultations, giving agents a private, reliable way to meet clients face-to-face online.',
    href: '/contact',
    cta: 'Ask about it',
  },
  {
    name: 'Prosperity Services Group',
    desc: 'Fixed indexed annuity and safe money planning site for retirement-focused clients.',
    href: 'https://prosperityservicesgroup.com',
    cta: 'Visit site',
    external: true,
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Purple Peaks Apps',
  url: 'https://purplepeaksapps.com',
  logo: 'https://purplepeaksapps.com/brand/purplepeaksapps-logo.png',
  description:
    'Purple Peaks Apps builds internal software tools for independent insurance agents, including the PSG Partner Portal, LearnMedicare.org, self-hosted video conferencing, and Prosperity Services Group.',
};

const speakableJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  url: 'https://purplepeaksapps.com/',
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.speakable-headline', '.speakable-answer'],
  },
};

const localBusinessJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Purple Peaks Apps',
  url: 'https://purplepeaksapps.com',
  logo: 'https://purplepeaksapps.com/brand/purplepeaksapps-logo.png',
  image: 'https://purplepeaksapps.com/brand/purplepeaksapps-logo.png',
  description:
    'Purple Peaks Apps is the technology development team behind Price Services Group, building custom software for independent insurance agencies including agent CRMs, Medicare education platforms, and self-hosted video conferencing.',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    url: 'https://purplepeaksapps.com/contact',
  },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What does Purple Peaks Apps build?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Purple Peaks Apps is the technology arm behind Price Services Group's digital tools. We build software that helps independent insurance agents manage clients, get educated, and meet with confidence, including an agent CRM and back-office portal, a free consumer education platform, and self-hosted video conferencing for client consultations.",
      },
    },
    {
      '@type': 'Question',
      name: 'What is the PSG Partner Portal?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The PSG Partner Portal is a back-office CRM built for independent insurance agents, bringing lead management, e-signature workflows, and quoting tools into one place so agents can spend less time on admin and more time with clients.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is LearnMedicare.org?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LearnMedicare.org is a free Medicare education platform featuring a 6-lesson video course, interactive calculators, and a T65 guide for people approaching Medicare eligibility.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Purple Peaks Apps offer video conferencing for client meetings?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Our Jitsi Video Rooms product provides secure, self-hosted video meeting rooms for client consultations, giving agents a private, reliable way to meet clients face-to-face online.',
      },
    },
    {
      '@type': 'Question',
      name: 'Who is Purple Peaks Apps built for?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Our products are built for independent insurance agents and agencies, with tools spanning agent-facing CRM and quoting software, consumer-facing education platforms, and retirement planning sites like Prosperity Services Group.',
      },
    },
  ],
};
---
<BaseLayout
  title="Purple Peaks Apps — Building Smart Tools for Insurance Professionals"
  description="Purple Peaks Apps is the technology arm behind Price Services Group's digital tools — building software that helps independent insurance agents work smarter."
  path="/"
  jsonLd={[jsonLd, localBusinessJsonLd, faqJsonLd, speakableJsonLd]}
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Purple Peaks Apps</p>
      <h1 class="speakable-headline">Building Smart Tools for Insurance Professionals.</h1>
      <p class="subhead speakable-answer">
        We're the technology arm behind Price Services Group's digital tools — building the
        software that helps independent insurance agents manage clients, get educated, and meet
        with confidence. Our work spans an agent CRM and back-office portal, a free consumer
        education platform, and self-hosted video conferencing for client consultations.
      </p>
      <a href="/contact" class="btn btn-primary">Get in Touch</a>
    </div>
  </section>

  <section>
    <div class="container">
      <p class="eyebrow">What We Build</p>
      <h2>Software for the way agents actually work.</h2>
      <div class="grid grid-4">
        {products.map((p) => (
          <div class="card product-card">
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
            <a href={p.href} target={p.external ? '_blank' : undefined} rel={p.external ? 'noopener noreferrer' : undefined} class="product-link">{p.cta} &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="about-section">
    <div class="container about-inner">
      <p class="eyebrow">About Purple Peaks Apps</p>
      <h2>Custom technology for independent insurance agencies</h2>

      <p>
        Purple Peaks Apps is the software development team behind Price Services Group, building
        the internal tools that let an independent insurance agency run like a much larger
        organization. We're not a general-purpose web shop — every product we build starts from
        the day-to-day reality of running a Medicare and health insurance book of business:
        chasing leads, tracking compliance deadlines, comparing plans across carriers, and keeping
        clients informed without drowning in paperwork. That focus shows up in what we build: an
        agent CRM and back-office portal, a free consumer-facing Medicare education platform, and
        self-hosted video conferencing for client consultations, alongside location-specific
        Medicare guides and retirement-planning sites for affiliated brands.
      </p>

      <p>
        Our stack is deliberately lean. Sites in the PSG family, including this one, are built
        with Astro and deployed on Cloudflare Pages, which keeps pages fast and inexpensive to
        run at scale. Where a project needs a database or serverless backend logic, we reach for
        Cloudflare D1 and Cloudflare Workers rather than standing up heavier infrastructure — the
        same edge-first approach across every site in the family, so agents get consistent
        performance and we get a codebase that's easier to maintain across dozens of properties.
      </p>

      <p>
        A few of the projects this approach has produced: <a href="https://priceservicesgroup.com" target="_blank" rel="noopener noreferrer">priceservicesgroup.com</a>,
        the primary Medicare and health insurance agency site, connecting consumers with licensed
        insurance agents across our service area. <a href="https://local.priceservicesgroup.com" target="_blank" rel="noopener noreferrer">local.priceservicesgroup.com</a>
        extends that reach with thousands of hyper-local, county-level Medicare guide pages so
        consumers searching for coverage information in their specific area can find it — and find
        a local agent. <a href="https://learnmedicare.org" target="_blank" rel="noopener noreferrer">learnmedicare.org</a>
        takes a different angle: free, unbiased Medicare education with no sales pitch attached,
        built to help people understand enrollment periods and coverage options before they ever
        talk to an agent. And the PSG Partner Portal, our agent-facing CRM, is where the leads,
        e-signatures, documents, and quoting from all of those consumer touchpoints come together
        for the agents actually doing the work. Together, this family of sites powers Price
        Services Group's entire digital presence, from first search to signed application.
      </p>

      <p>
        Insurance agencies have needs that off-the-shelf software rarely fits well. Compliance
        requirements are strict and change often. Lead flow needs to connect cleanly to
        e-signature and enrollment workflows instead of living in a separate disconnected tool.
        Consumers researching Medicare want plain-English answers, not a sales funnel, at least
        until they're ready to talk to someone. Generic CRMs and website builders are built for a
        much broader audience and force agencies to bend their process around the software. We
        build the other way around: software shaped by how an agency actually operates day to
        day, so the tools fit the work instead of the other way around.
      </p>

      <p>
        We also think about these products as a connected system rather than a set of standalone
        sites. A consumer might first land on a location-specific Medicare guide, move to
        LearnMedicare.org to understand their options in plain language, and eventually reach out
        through priceservicesgroup.com — while the agent handling that lead works the whole
        relationship inside the Partner Portal, from first contact through signed enrollment
        paperwork. Building all of these pieces ourselves, on a shared and consistent stack, means
        the handoffs between them are seamless instead of stitched together with workarounds, and
        it means we can add a new location page, a new portal feature, or a new education module
        without waiting on an outside vendor's roadmap.
      </p>

      <p>
        If you run an independent insurance agency and are outgrowing spreadsheets, disconnected
        CRMs, or a website that doesn't reflect how you actually work with clients, we'd like to
        hear about it. <a href="/contact">Get in touch</a> and we can talk through what a custom
        portal, education site, or agency website could look like for your team.
      </p>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Have a project or idea to talk through?</h2>
      <p>We'd like to hear from you.</p>
      <a href="/contact" class="btn btn-teal">Get in Touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-dark) 0%, #2b1147 100%);
    color: #fff;
    padding: 6rem 0;
  }
  .hero-inner { max-width: 720px; }
  .hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3.2rem); }
  .hero .eyebrow { color: var(--color-teal); }
  .subhead { font-size: 1.1rem; color: #e2d4f0; margin-bottom: 1.75rem; }

  .product-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .product-card h3 { margin-bottom: 0.2rem; }
  .product-card p { color: var(--color-text-muted); font-size: 0.95rem; flex-grow: 1; }
  .product-link {
    font-weight: 700;
    text-decoration: none;
    color: var(--color-purple);
    font-size: 0.92rem;
  }
  :root[data-theme="dark"] .product-link { color: var(--color-teal); }

  .about-section { padding: 4rem 0; }
  .about-inner { max-width: 780px; margin: 0 auto; }
  .about-inner .eyebrow { color: var(--color-purple); }
  :root[data-theme="dark"] .about-inner .eyebrow { color: var(--color-teal); }
  .about-inner h2 { margin-bottom: 1.25rem; }
  .about-inner p {
    color: var(--color-text);
    font-size: 1.02rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .about-inner a { color: var(--color-purple); }
  :root[data-theme="dark"] .about-inner a { color: var(--color-teal); }

  .cta-section {
    background: var(--color-purple);
    color: #fff;
    text-align: center;
  }
  .cta-inner h2 { color: #fff; }
  .cta-inner p { color: #f0e6f8; margin-bottom: 1.5rem; }
</style>
