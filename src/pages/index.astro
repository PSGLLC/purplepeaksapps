---
import BaseLayout from '../layouts/BaseLayout.astro';

const products = [
  {
    name: 'ProShot AI',
    desc: 'AI-powered photo enhancement that sharpens, retouches, and upgrades headshots and product photos in seconds — no editing skills required.',
    href: 'https://proshot-ai.higgsfield.app/',
    cta: 'Try it',
    external: true,
  },
  {
    name: 'PSG Partner Portal',
    desc: 'A back-office CRM built for independent insurance agents — bringing lead management, e-signature workflows, and quoting tools into one place so agents can spend less time on admin and more time with clients.',
    href: '/portal',
    cta: 'Learn more',
  },
  {
    name: 'LearnMedicare.org',
    desc: 'Free Medicare education platform with 6-lesson video course, interactive calculators, and T65 guide lead capture.',
    href: 'https://learnmedicare.org',
    cta: 'Visit site',
    external: true,
  },
  {
    name: 'Jitsi Video Rooms',
    desc: 'Secure, self-hosted video meeting rooms for client consultations, giving agents a private, reliable way to meet clients face-to-face online.',
    href: '/contact',
    cta: 'Ask about it',
  },
  {
    name: 'Prosperity Services Group',
    desc: 'Fixed indexed annuity and safe money planning site for retirement-focused clients.',
    href: 'https://prosperityservicesgroup.com',
    cta: 'Visit site',
    external: true,
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Purple Peaks Apps LLC',
  url: 'https://purplepeaksapps.com',
  logo: 'https://purplepeaksapps.com/brand/purplepeaksapps-logo.png',
  description: 'Custom software, apps, and websites for small businesses.',
  sameAs: ['https://priceservicesgroup.com', 'https://purplepeaksapps.com'],
};

const speakableJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  url: 'https://purplepeaksapps.com/',
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.speakable-headline', '.speakable-answer'],
  },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What does Purple Peaks Apps build?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Purple Peaks Apps is the technology arm behind Price Services Group's digital tools. We build software that helps independent insurance agents manage clients, get educated, and meet with confidence, including an agent CRM and back-office portal, a free consumer education platform, and self-hosted video conferencing for client consultations.",
      },
    },
    {
      '@type': 'Question',
      name: 'What is the PSG Partner Portal?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The PSG Partner Portal is a back-office CRM built for independent insurance agents, bringing lead management, e-signature workflows, and quoting tools into one place so agents can spend less time on admin and more time with clients.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is LearnMedicare.org?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LearnMedicare.org is a free Medicare education platform featuring a 6-lesson video course, interactive calculators, and a T65 guide for people approaching Medicare eligibility.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Purple Peaks Apps offer video conferencing for client meetings?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Our Jitsi Video Rooms product provides secure, self-hosted video meeting rooms for client consultations, giving agents a private, reliable way to meet clients face-to-face online.',
      },
    },
    {
      '@type': 'Question',
      name: 'Who is Purple Peaks Apps built for?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Our products are built for independent insurance agents and agencies, with tools spanning agent-facing CRM and quoting software, consumer-facing education platforms, and retirement planning sites like Prosperity Services Group.',
      },
    },
  ],
};
---
<BaseLayout
  title="Purple Peaks Apps — Smart Tools for Small Businesses"
  description="Purple Peaks Apps builds digital tools for small businesses — client portals, education platforms, AI-powered apps, and the websites that tie it all together."
  path="/"
  jsonLd={[jsonLd, faqJsonLd, speakableJsonLd]}
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Purple Peaks Apps</p>
      <h1 class="speakable-headline">Building Smart Tools for Small Businesses.</h1>
      <p class="subhead speakable-answer">
        We build the software, sites, and digital tools that help small businesses run smarter —
        from client portals and education platforms to AI-powered apps and self-hosted video.
      </p>
      <a href="/contact" class="btn btn-primary">Get in Touch</a>
    </div>
  </section>

  <section>
    <div class="container">
      <p class="eyebrow">What We Build</p>
      <h2>Tools and apps built for the way small businesses actually work.</h2>
      <div class="grid grid-4">
        {products.map((p) => (
          <div class="card product-card">
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
            <a href={p.href} target={p.external ? '_blank' : undefined} rel={p.external ? 'noopener noreferrer' : undefined} class="product-link">{p.cta} &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="apps-teaser">
    <div class="container">
      <p class="eyebrow">Our Apps</p>
      <h2>Tools you can use right now.</h2>
      <p class="apps-teaser-sub">We build focused apps for real tasks — no account required.</p>
      <div class="grid grid-3 apps-teaser-grid">
        <div class="card product-card">
          <span class="app-badge">AI-Powered</span>
          <h3>ProShot AI</h3>
          <p>Sharpen, retouch, and upgrade headshots and product photos in seconds — no editing skills or software required.</p>
          <a href="https://proshot-ai.higgsfield.app/" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Try it &rarr;</a>
        </div>
      </div>
      <a href="/apps" class="apps-teaser-link">See all apps &rarr;</a>
    </div>
  </section>

  <section class="about-section">
    <div class="container about-inner">
      <p class="eyebrow">About Purple Peaks Apps</p>
      <h2>Custom technology for small businesses</h2>

      <p>
        Purple Peaks Apps is a software development team that builds custom tools for small
        businesses — client portals, education platforms, AI-powered apps, and the websites that
        tie it all together. We're not a general-purpose web shop cranking out templates. Every
        product we build starts from the day-to-day reality of running a small business: chasing
        leads, keeping clients informed, managing documents and workflows, and doing it all
        without a team of developers on staff. That's the gap we fill.
      </p>

      <p>
        Our stack is deliberately lean. Sites we build are put together with Astro and deployed
        on Cloudflare Pages, which keeps pages fast and inexpensive to run at scale. Where a
        project needs a database or serverless backend logic, we reach for Cloudflare D1 and
        Cloudflare Workers rather than standing up heavier infrastructure — the same edge-first
        approach across every project, so clients get consistent performance and we get a
        codebase that's easy to maintain across many properties.
      </p>

      <p>
        Price Services Group, an independent Medicare and health insurance agency, is our biggest
        and longest-running client, and a good example of what this looks like in practice. For
        PSG we've built <a href="https://priceservicesgroup.com" target="_blank" rel="noopener noreferrer">priceservicesgroup.com</a>,
        the agency's primary site connecting consumers with licensed agents;
        <a href="https://local.priceservicesgroup.com" target="_blank" rel="noopener noreferrer">local.priceservicesgroup.com</a>,
        with thousands of hyper-local, county-level guide pages; <a href="https://learnmedicare.org" target="_blank" rel="noopener noreferrer">learnmedicare.org</a>,
        a free education platform with no sales pitch attached; and the PSG Partner Portal, an
        agent-facing CRM where leads, e-signatures, documents, and quoting all come together.
        We've also built tools that go beyond any one industry, like ProShot AI, our AI-powered
        photo enhancement app for headshots and product photos.
      </p>

      <p>
        Small businesses have needs that off-the-shelf software rarely fits well. Workflows are
        specific to how the business actually operates, not how a generic SaaS product assumes
        every customer works. Customers want plain, direct answers, not a sales funnel, until
        they're ready to talk to someone. Generic CRMs, website builders, and app platforms are
        built for the broadest possible audience and force a business to bend its process around
        the software. We build the other way around: software shaped by how the business actually
        works, so the tools fit the work instead of the other way around.
      </p>

      <p>
        We also think about these products as connected systems rather than standalone tools. A
        customer might first land on a business's website, move to an education or self-service
        tool to understand their options, and eventually reach out to the business directly —
        while the team on the other end works the relationship inside a portal built for exactly
        that job. Building these pieces ourselves, on a shared and consistent stack, means the
        handoffs between them are seamless instead of stitched together with workarounds, and it
        means we can add a new page, a new portal feature, or a new tool without waiting on an
        outside vendor's roadmap.
      </p>

      <p>
        If you run a small business and are outgrowing spreadsheets, disconnected tools, or a
        website that doesn't reflect how you actually work with clients, we'd like to hear about
        it. <a href="/contact">Get in touch</a> and we can talk through what a custom portal,
        app, or website could look like for your team.
      </p>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Have a project or idea to talk through?</h2>
      <p>We'd like to hear from you.</p>
      <a href="/contact" class="btn btn-teal">Get in Touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-dark) 0%, #2b1147 100%);
    color: #fff;
    padding: 6rem 0;
  }
  .hero-inner { max-width: 720px; }
  .hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3.2rem); }
  .hero .eyebrow { color: var(--color-teal); }
  .subhead { font-size: 1.1rem; color: #e2d4f0; margin-bottom: 1.75rem; }

  .product-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .product-card h3 { margin-bottom: 0.2rem; }
  .product-card p { color: var(--color-text-muted); font-size: 0.95rem; flex-grow: 1; }
  .product-link {
    font-weight: 700;
    text-decoration: none;
    color: var(--color-purple);
    font-size: 0.92rem;
  }
  :root[data-theme="dark"] .product-link { color: var(--color-teal); }

  .apps-teaser { padding: 4rem 0; background: var(--color-bg-alt); }
  .apps-teaser-sub { color: var(--color-text-muted); font-size: 1.05rem; margin: 0.5rem 0 2rem; }
  .apps-teaser-grid { max-width: 420px; margin-bottom: 1.5rem; }
  .apps-teaser-link {
    display: inline-block;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-purple);
  }
  :root[data-theme="dark"] .apps-teaser-link { color: var(--color-teal); }

  .app-badge {
    display: inline-block;
    align-self: flex-start;
    background: rgba(81, 222, 204, 0.15);
    color: var(--color-purple);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    margin-bottom: 0.3rem;
  }
  :root[data-theme="dark"] .app-badge { color: var(--color-teal); }

  .about-section { padding: 4rem 0; }
  .about-inner { max-width: 780px; margin: 0 auto; }
  .about-inner .eyebrow { color: var(--color-purple); }
  :root[data-theme="dark"] .about-inner .eyebrow { color: var(--color-teal); }
  .about-inner h2 { margin-bottom: 1.25rem; }
  .about-inner p {
    color: var(--color-text);
    font-size: 1.02rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .about-inner a { color: var(--color-purple); }
  :root[data-theme="dark"] .about-inner a { color: var(--color-teal); }

  .cta-section {
    background: var(--color-purple);
    color: #fff;
    text-align: center;
  }
  .cta-inner h2 { color: #fff; }
  .cta-inner p { color: #f0e6f8; margin-bottom: 1.5rem; }
</style>
