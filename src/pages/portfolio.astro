---
import BaseLayout from '../layouts/BaseLayout.astro';

const sites = [
  {
    name: 'Price Services Group',
    desc: 'Medicare & insurance agency site.',
    href: 'https://priceservicesgroup.com',
  },
  {
    name: 'PSG Partner Portal',
    desc: 'Agent and client management portal.',
    href: 'https://partner.priceservicesgroup.com',
  },
  {
    name: 'LearnMedicare.org',
    desc: 'Free Medicare education platform.',
    href: 'https://learnmedicare.org',
  },
  {
    name: 'Local Medicare Guide',
    desc: '3,266 location pages for Eastern NC.',
    href: 'https://local.priceservicesgroup.com',
  },
  {
    name: 'Prosperity Services Group',
    desc: 'Fixed indexed annuity and safe money planning.',
    href: 'https://prosperityservicesgroup.com',
  },
  {
    name: 'Prosperity Federal Solutions',
    desc: 'Government procurement and supply.',
    href: 'https://prosperityfederalsolutions.com',
  },
  {
    name: 'PSG Jitsi Video',
    desc: 'Self-hosted branded video meeting rooms.',
    href: 'https://meet.priceservicesgroup.com',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Portfolio | Purple Peaks Apps',
  url: 'https://purplepeaksapps.com/portfolio',
  description:
    'The full portfolio of sites and tools built by Purple Peaks Apps for Price Services Group and its affiliated brands.',
};
---
<BaseLayout
  title="Portfolio — Sites We've Built | Purple Peaks Apps"
  description="Browse the full portfolio of sites and tools built by Purple Peaks Apps, including Price Services Group, the PSG Partner Portal, LearnMedicare.org, and more."
  path="/portfolio"
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Portfolio</p>
      <h1>Sites we've built.</h1>
      <p class="subhead">
        A look at the full family of sites and tools Purple Peaks Apps has built and maintains for
        Price Services Group and its affiliated brands.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid grid-3">
        {sites.map((s) => (
          <div class="card product-card">
            <h3>{s.name}</h3>
            <p>{s.desc}</p>
            <a href={s.href} target="_blank" rel="noopener noreferrer" class="btn btn-primary">Visit Site</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Have a project or idea to talk through?</h2>
      <p>We'd like to hear from you.</p>
      <a href="/contact" class="btn btn-teal">Get in Touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-dark) 0%, #2b1147 100%);
    color: #fff;
    padding: 5.5rem 0;
  }
  .hero-inner { max-width: 720px; }
  .hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3.2rem); }
  .hero .eyebrow { color: var(--color-teal); }
  .subhead { font-size: 1.1rem; color: #e2d4f0; margin-bottom: 0; }

  .product-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .product-card h3 { margin-bottom: 0.2rem; }
  .product-card p { color: var(--color-text-muted); font-size: 0.95rem; flex-grow: 1; }
  .product-card .btn { align-self: flex-start; margin-top: 0.5rem; }

  .cta-section {
    background: var(--color-purple);
    color: #fff;
    text-align: center;
  }
  .cta-inner h2 { color: #fff; }
  .cta-inner p { color: #f0e6f8; margin-bottom: 1.5rem; }
</style>
