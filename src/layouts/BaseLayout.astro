---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { SITE_URL } from '../site.config';

interface Props {
  title: string;
  description: string;
  path: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  ogImage?: string;
}

const { title, description, path, jsonLd, ogImage = '/brand/purplepeaksapps-logo.png' } = Astro.props;
const normalizedPath = path.includes('.') || path.endsWith('/') ? path : `${path}/`;
const canonical = new URL(normalizedPath, SITE_URL).toString();
const ogImageUrl = new URL(ogImage, SITE_URL).toString();

const segments = path.split('/').filter(Boolean);
const crumbLabels: Record<string, string> = {
  portal: 'Portal',
  learn: 'Learn',
  portfolio: 'Portfolio',
  contact: 'Contact',
  faq: 'FAQ',
  privacy: 'Privacy Policy',
  terms: 'Terms of Use',
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE_URL + '/',
    },
    ...segments.map((seg, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: crumbLabels[seg] ?? seg.charAt(0).toUpperCase() + seg.slice(1),
      item: new URL('/' + segments.slice(0, i + 1).join('/'), SITE_URL).toString(),
    })),
  ],
};

const jsonLdEntries = [
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
  ...(segments.length > 0 ? [breadcrumbJsonLd] : []),
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/brand/purplepeaksapps-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Purple Peaks Apps" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {jsonLdEntries.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}

    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
